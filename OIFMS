  };
  const pillars = [
    {id:"p1",n:"01",t:"AI Budget Copilot",desc:"NLP chatbot for budget queries in Odia & English",icon:"chat",grad:`linear-gradient(135deg,${C.s800},${C.s500})`,priority:"critical"},
    {id:"p2",n:"02",t:"Design System",desc:"40+ components, WCAG 2.1 AA, token-based theming",icon:"layers",grad:`linear-gradient(135deg,${C.s700},${C.s400})`,priority:"critical"},
    {id:"p3",n:"03",t:"Analytics Dashboard",desc:"Real-time charts with AI anomaly detection",icon:"bar",grad:`linear-gradient(135deg,${C.s600},${C.s300})`,priority:"critical"},
