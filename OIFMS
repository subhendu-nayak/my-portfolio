/* ─── SHARED COMPONENTS ──────────────────────────── */
const Btn = ({ children, variant="primary", sm, onClick, disabled, style={} }) => {
  const base = { display:"inline-flex", alignItems:"center", gap:7, fontFamily:"Roboto,sans-serif", fontWeight:600, border:"none", cursor: disabled?"not-allowed":"pointer", borderRadius:30, transition:"all .2s", fontSize:sm?12:13, padding:sm?"7px 14px":"10px 20px", opacity:disabled?.5:1, ...style };
  const variants = {
    primary:{ background:`linear-gradient(135deg,${C.s700},${C.s500})`, color:"white", boxShadow:`0 3px 12px rgba(14,165,233,.3)` },
    secondary:{ background:C.s50, color:C.s700, border:`1.5px solid ${C.s200}` },
    danger:{ background:`linear-gradient(135deg,#DC2626,${C.red})`, color:"white" },
    success:{ background:`linear-gradient(135deg,#059669,${C.green})`, color:"white" },
    ghost:{ background:"transparent", color:C.s700, border:`1.5px solid ${C.s300}` },
  };
  return <button style={{...base,...variants[variant]}} onClick={disabled?null:onClick} disabled={disabled}>{children}</button>;
};

const Card = ({ children, style={} }) => (
  <div style={{ background:C.white, borderRadius:16, border:`1px solid ${C.border}`, boxShadow:`0 2px 12px rgba(14,165,233,.06)`, ...style }}>{children}</div>
);

const Badge = ({ children, color="sky", style={} }) => {
  const colors = { sky:{bg:C.s100,c:C.s700}, green:{bg:"#D1FAE5",c:"#065F46"}, red:{bg:"#FEE2E2",c:"#991B1B"}, amber:{bg:"#FEF3C7",c:"#92400E"}, purple:{bg:"#EDE9FE",c:"#5B21B6"}, white:{bg:"rgba(255,255,255,.18)",c:"white",border:"1px solid rgba(255,255,255,.3)"} };
  const col = colors[color]||colors.sky;
  return <span style={{ display:"inline-flex", alignItems:"center", gap:4, fontSize:10, fontWeight:700, letterSpacing:.8, textTransform:"uppercase", padding:"3px 9px", borderRadius:30, background:col.bg, color:col.c, border:col.border||"none", ...style }}>{children}</span>;
};

const Prog = ({ pct, color, height=6 }) => (
  <div style={{ height, background:C.s100, borderRadius:height, overflow:"hidden" }}>
    <div style={{ height:"100%", width:`${Math.min(pct,100)}%`, background:color||`linear-gradient(90deg,${C.s700},${C.s400})`, borderRadius:height, transition:"width .8s ease" }}/>
  </div>
);

const IcoBox = ({ icon, size=40, br=11, grad=`linear-gradient(135deg,${C.s700},${C.s500})`, style={} }) => (
  <div style={{ width:size, height:size, borderRadius:br, background:grad, display:"flex", alignItems:"center", justifyContent:"center", flexShrink:0, ...style }}>
    <I n={icon} s={size*.44} />
  </div>
);

const Toggle = ({ on, onChange }) => (
  <div onClick={onChange} style={{ width:36, height:20, borderRadius:10, cursor:"pointer", transition:"background .2s", background:on?`linear-gradient(135deg,${C.s700},${C.s500})`:C.border, position:"relative", flexShrink:0 }}>
    <div style={{ position:"absolute", top:2, left:on?18:2, width:16, height:16, borderRadius:"50%", background:"white", transition:"left .2s", boxShadow:"0 1px 4px rgba(0,0,0,.2)" }}/>
  </div>
);

/* ─── TOAST SYSTEM ───────────────────────────────── */
let _addToast = null;
const Toast = () => {
  const [toasts, setToasts] = useState([]);
  useEffect(() => {
    _addToast = (msg, type="info") => {
      const id = Date.now() + Math.random();
      setToasts(t => [...t, { id, msg, type }]);
      setTimeout(() => setToasts(t => t.filter(x => x.id !== id)), 3500);
    };
  }, []);
  const icons = { info:C.s700, success:"#059669", warning:"#D97706", error:"#DC2626" };
  const bgs = { info:C.s100, success:"#D1FAE5", warning:"#FEF3C7", error:"#FEE2E2" };
  return (
    <div style={{ position:"fixed", top:70, right:16, zIndex:9999, display:"flex", flexDirection:"column", gap:8 }}>
      {toasts.map(t => (
        <div key={t.id} style={{ background:C.white, borderRadius:12, border:`1px solid ${C.border}`, padding:"11px 13px", display:"flex", alignItems:"center", gap:10, boxShadow:`0 6px 28px rgba(14,165,233,.14)`, minWidth:240, maxWidth:300, animation:"fadeInRight .25s ease" }}>
          <div style={{ width:28, height:28, borderRadius:8, background:bgs[t.type], flexShrink:0, display:"flex", alignItems:"center", justifyContent:"center" }}>
            <I n={t.type==="success"?"check":t.type==="error"?"x":t.type==="warning"?"warning":"info"} s={14} col={icons[t.type]} sw={2.5}/>
          </div>
          <span style={{ fontSize:13, color:C.ink2, flex:1 }}>{t.msg}</span>
          <button onClick={() => setToasts(ts => ts.filter(x => x.id !== t.id))} style={{ width:18, height:18, borderRadius:5, background:C.s50, border:"none", cursor:"pointer", display:"flex", alignItems:"center", justifyContent:"center" }}><I n="x" s={10} col={C.ink4} sw={2.5}/></button>
        </div>
      ))}
    </div>
  );
};
const toast = (msg, type) => _addToast && _addToast(msg, type);

/* ─── PAGE HEADER ─────────────────────────────────── */
const PageHeader = ({ num, tag, tagIcon="cpu", title, desc, priority="critical" }) => (
  <div style={{ padding:"24px 24px 20px", background:`linear-gradient(135deg,${C.s50},${C.white})`, borderBottom:`1px solid ${C.border}` }}>
    <div style={{ display:"flex", alignItems:"flex-start", gap:16 }}>
      <div style={{ width:50, height:50, borderRadius:14, background:`linear-gradient(135deg,${C.s700},${C.s500})`, display:"flex", alignItems:"center", justifyContent:"center", flexShrink:0, boxShadow:`0 4px 16px rgba(14,165,233,.28)`, fontSize:18, fontWeight:900, color:"white" }}>{num}</div>
      <div>
        <div style={{ display:"inline-flex", alignItems:"center", gap:6, background:C.s100, color:C.s700, fontSize:9, fontWeight:700, letterSpacing:2, textTransform:"uppercase", padding:"3px 12px", borderRadius:30, marginBottom:8 }}>
          <I n={tagIcon} s={10} col={C.s700} sw={2}/> {tag}
        </div>
        <h2 style={{ fontSize:"clamp(18px,3vw,26px)", fontWeight:900, color:C.ink, letterSpacing:-.5, marginBottom:6 }}>{title}</h2>
        <p style={{ fontSize:13, color:C.ink3, lineHeight:1.7, maxWidth:600, margin:0 }}>{desc}</p>
        <span style={{ display:"inline-flex", alignItems:"center", gap:5, fontSize:10, fontWeight:700, padding:"3px 10px", borderRadius:30, marginTop:8, background:priority==="critical"?"#FEE2E2":priority==="high"?"#FEF3C7":"#EDE9FE", color:priority==="critical"?"#991B1B":priority==="high"?"#92400E":"#5B21B6" }}>● {priority.charAt(0).toUpperCase()+priority.slice(1)} Priority</span>
      </div>
    </div>
  </div>
);

/* ══════════════════════════════════════════════════════
   P0 — COMMAND CENTER
══════════════════════════════════════════════════════ */
