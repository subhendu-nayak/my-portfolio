    {id:"p13",n:"13",t:"Voice Navigation",desc:"Odia + English AI — India's first govt voice system",icon:"mic",grad:`linear-gradient(135deg,${C.s800},${C.s500})`,priority:"future"},
    {id:"p14",n:"14",t:"IFMS Academy",desc:"Gamified training for 15,000+ users statewide",icon:"book",grad:`linear-gradient(135deg,${C.s700},${C.s400})`,priority:"high"},
    {id:"p15",n:"15",t:"Open API Hub",desc:"REST API connecting PFMS, HRMS, GST, Banks",icon:"link",grad:`linear-gradient(135deg,${C.s800},${C.s500})`,priority:"future"},
    {id:"p16",n:"16",t:"Sentiment Analytics",desc:"Heatmaps, NPS surveys, UX health scoring",icon:"eye",grad:`linear-gradient(135deg,${C.s600},${C.s400})`,priority:"high"},
    {id:"p17",n:"17",t:"Blockchain Ledger",desc:"Immutable audit trail, CAG verification",icon:"block",grad:`linear-gradient(135deg,${C.s900},${C.s800})`,priority:"future"},
    {id:"p18",n:"18",t:"Accessibility",desc:"WCAG 2.1 AA, screen reader, Odia localization",icon:"clock",grad:`linear-gradient(135deg,${C.s700},${C.s500})`,priority:"high"},
  ];
  const months = ["Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec","Jan","Feb","Mar"];
  const vals = [60,75,55,85,70,92,78,84,95,100,88,80];
  return (
    <div>
      <div style={{ padding:"24px 24px 20px", background:`linear-gradient(135deg,${C.s900},${C.s700})`, color:"white" }}>
        <div style={{ display:"flex", alignItems:"center", justifyContent:"space-between", marginBottom:4, flexWrap:"wrap", gap:8 }}>
          <div>
            <div style={{ display:"inline-flex", alignItems:"center", gap:6, background:"rgba(255,255,255,.12)", border:"1px solid rgba(255,255,255,.2)", borderRadius:30, padding:"3px 12px", fontSize:9, fontWeight:700, letterSpacing:2, textTransform:"uppercase", marginBottom:8 }}>
