    {id:"p5",n:"05",t:"Fraud Detection",desc:"ML model, real-time risk scoring, auto-hold",icon:"shield",grad:`linear-gradient(135deg,${C.s900},${C.s700})`,priority:"critical"},
    {id:"p6",n:"06",t:"Predictive Forecasting",desc:"Time-series AI, 89% accuracy, scenario modeling",icon:"activity",grad:`linear-gradient(135deg,${C.s600},${C.s300})`,priority:"high"},
    {id:"p7",n:"07",t:"Role-Based UI",desc:"Adaptive interface per DDO, Treasury, Secretary",icon:"user",grad:`linear-gradient(135deg,${C.s700},${C.s500})`,priority:"high"},
