  const navGroups = [
    { label:"Overview", items:[{ id:"p0", icon:"grid", label:"Command Center" }] },
    { label:"AI Modules", items:[{ id:"p1",icon:"chat",label:"01 · Budget Copilot" },{ id:"p5",icon:"shield",label:"05 · Fraud Detection",badge:"3",badgeRed:true },{ id:"p6",icon:"activity",label:"06 · Forecasting" },{ id:"p8",icon:"doc",label:"08 · OCR Engine" },{ id:"p13",icon:"mic",label:"13 · Voice Navigation" }] },
    { label:"Finance Ops", items:[{ id:"p3",icon:"bar",label:"03 · Analytics" },{ id:"p4",icon:"flow",label:"04 · Workflow" },{ id:"p11",icon:"download",label:"11 · Reports" },{ id:"p9",icon:"pin",label:"09 · GIS Fund Map" }] },
    { label:"UX & Design", items:[{ id:"p2",icon:"layers",label:"02 · Design System" },{ id:"p7",icon:"user",label:"07 · Role-Based UI" },{ id:"p12",icon:"phone",label:"12 · Mobile PWA" },{ id:"p18",icon:"clock",label:"18 · Accessibility" },{ id:"p16",icon:"eye",label:"16 · Sentiment" }] },
    { label:"Infra & Gov", items:[{ id:"p10",icon:"bell",label:"10 · Notifications" },{ id:"p14",icon:"book",label:"14 · IFMS Academy" },{ id:"p15",icon:"link",label:"15 · API Hub" },{ id:"p17",icon:"block",label:"17 · Blockchain" }] },
  ];

  const pageTitles = { p0:"Command Center",p1:"AI Budget Copilot",p2:"Design System",p3:"Analytics Dashboard",p4:"Smart Workflow",p5:"Fraud Detection",p6:"Predictive Forecasting",p7:"Role-Based UI",p8:"OCR Engine",p9:"GIS Fund Map",p10:"Notifications",p11:"Zero-Click Reports",p12:"Mobile PWA",p13:"Voice Navigation",p14:"IFMS Academy",p15:"Open API Hub",p16:"Sentiment Analytics",p17:"Blockchain Ledger",p18:"Accessibility" };

  return (
    <div style={{ display:"flex", height:"100vh", overflow:"hidden", fontFamily:"Roboto,sans-serif" }}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700;900&family=Roboto+Mono:wght@400;500&display=swap');
        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family:'Roboto',sans-serif; }
        ::-webkit-scrollbar { width:4px; height:4px; }
        ::-webkit-scrollbar-track { background:transparent; }
        ::-webkit-scrollbar-thumb { background:#BAE6FD; border-radius:4px; }
        @keyframes fadeUp { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }
        @keyframes fadeInRight { from{opacity:0;transform:translateX(20px)} to{opacity:1;transform:translateX(0)} }
        @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
        @keyframes spin { to{transform:rotate(360deg)} }
        @keyframes wv { 0%,100%{transform:scaleY(.3)} 50%{transform:scaleY(1)} }
        @keyframes glow { 0%,100%{box-shadow:0 0 0 0 rgba(14,165,233,.4)} 50%{box-shadow:0 0 0 14px rgba(14,165,233,0)} }
        select { cursor:pointer; }
        @media(max-width:768px){
          .sidebar-wrap { position:fixed!important; z-index:100; transform:${sidebarOpen?"translateX(0)":"translateX(-100%)"}!important; transition:transform .3s!important; }
        }
      `}</style>

      {/* Overlay */}
      {sidebarOpen && <div onClick={()=>setSidebarOpen(false)} style={{ position:"fixed", inset:0, background:"rgba(0,0,0,.5)", zIndex:99 }}/>}

      {/* Sidebar */}
      <aside className="sidebar-wrap" style={{ width:260, flexShrink:0, background:`linear-gradient(175deg,${C.s900},${C.s800} 55%,${C.s700})`, display:"flex", flexDirection:"column", zIndex:50 }}>
        <div style={{ padding:"18px 14px 14px", borderBottom:"1px solid rgba(255,255,255,.1)", display:"flex", alignItems:"center", gap:10 }}>
          <div style={{ width:34, height:34, borderRadius:9, background:"rgba(255,255,255,.15)", border:"1px solid rgba(255,255,255,.2)", display:"flex", alignItems:"center", justifyContent:"center", flexShrink:0 }}><I n="cpu" s={17}/></div>
          <div><div style={{ fontSize:14, fontWeight:700, color:"white" }}>OIFMS 3.0</div><div style={{ fontSize:9, color:"rgba(255,255,255,.45)", letterSpacing:1.5, textTransform:"uppercase" }}>Innovation Portal</div></div>
        </div>
        <div style={{ flex:1, overflowY:"auto", padding:"8px 10px" }}>
          {navGroups.map(g => (
            <div key={g.label}>
              <div style={{ fontSize:9, fontWeight:700, letterSpacing:2, textTransform:"uppercase", color:"rgba(255,255,255,.35)", padding:"12px 8px 5px" }}>{g.label}</div>
              {g.items.map(item => (
                <div key={item.id} onClick={()=>navigate(item.id)} style={{ display:"flex", alignItems:"center", gap:10, padding:"9px 10px", borderRadius:11, cursor:"pointer", transition:"all .2s", color:page===item.id?"white":"rgba(255,255,255,.6)", background:page===item.id?"rgba(255,255,255,.16)":"transparent", marginBottom:1, position:"relative", fontSize:12, fontWeight:500 }}>
                  {page===item.id && <div style={{ position:"absolute", left:0, top:"50%", transform:"translateY(-50%)", width:3, height:"60%", background:"white", borderRadius:"0 3px 3px 0" }}/>}
                  <div style={{ width:18, height:18, display:"flex", alignItems:"center", justifyContent:"center", flexShrink:0 }}><I n={item.icon} s={16} col={page===item.id?"white":"rgba(255,255,255,.6)"} sw={2}/></div>
                  <span style={{ flex:1 }}>{item.label}</span>
                  {item.badge && <span style={{ background:item.badgeRed?C.red:"rgba(255,255,255,.18)", color:"white", fontSize:9, fontWeight:700, padding:"1px 6px", borderRadius:30 }}>{item.badge}</span>}
                </div>
              ))}
            </div>
          ))}
        </div>
        <div style={{ padding:"12px 10px", borderTop:"1px solid rgba(255,255,255,.1)" }}>
          <div style={{ display:"flex", alignItems:"center", gap:9, padding:"9px 10px", borderRadius:11, background:"rgba(255,255,255,.08)", cursor:"pointer" }}>
            <div style={{ width:32, height:32, borderRadius:"50%", background:`linear-gradient(135deg,${C.s400},${C.s200})`, display:"flex", alignItems:"center", justifyContent:"center", fontSize:12, fontWeight:700, color:C.s900, flexShrink:0 }}>SN</div>
            <div><div style={{ fontSize:12, fontWeight:600, color:"white" }}>Subhendu Nayak</div><div style={{ fontSize:10, color:"rgba(255,255,255,.45)" }}>UI/UX Designer</div></div>
          </div>
        </div>
      </aside>

      {/* Main */}
      <div style={{ flex:1, display:"flex", flexDirection:"column", overflow:"hidden" }}>
        {/* Topbar */}
        <div style={{ height:56, flexShrink:0, background:C.white, borderBottom:`1px solid ${C.border}`, display:"flex", alignItems:"center", padding:"0 16px", gap:12, boxShadow:`0 1px 6px rgba(14,165,233,.06)` }}>
          <button onClick={()=>setSidebarOpen(s=>!s)} style={{ width:34, height:34, borderRadius:8, border:"none", background:C.s50, cursor:"pointer", display:"flex", alignItems:"center", justifyContent:"center", flexShrink:0 }}>
            <I n="menu" s={18} col={C.s700} sw={2}/>
          </button>
          <div style={{ fontSize:15, fontWeight:700, color:C.ink, flex:1, minWidth:0, whiteSpace:"nowrap", overflow:"hidden", textOverflow:"ellipsis" }}>{pageTitles[page]||"OIFMS 3.0"}</div>
          <div style={{ display:"flex", alignItems:"center", gap:8, background:C.s50, border:`1.5px solid ${C.border}`, borderRadius:30, padding:"6px 13px", maxWidth:280, flex:1 }}>
            <I n="search" s={14} col={C.ink4} sw={2}/>
            <input value={search} onChange={e=>setSearch(e.target.value)} placeholder="Search modules..." style={{ border:"none", background:"transparent", fontFamily:"Roboto,sans-serif", fontSize:12, color:C.ink, outline:"none", flex:1 }}/>
          </div>
          <button onClick={()=>{ navigate("p10"); toast("Opening notifications","info"); }} style={{ width:34, height:34, borderRadius:8, border:"none", background:C.s50, cursor:"pointer", display:"flex", alignItems:"center", justifyContent:"center", position:"relative", flexShrink:0 }}>
            <I n="bell" s={16} col={C.s700} sw={2}/>
            <div style={{ position:"absolute", top:6, right:6, width:7, height:7, borderRadius:"50%", background:C.red, border:"2px solid white" }}/>
          </button>
          <button onClick={()=>toast("Settings panel","info")} style={{ width:34, height:34, borderRadius:8, border:"none", background:C.s50, cursor:"pointer", display:"flex", alignItems:"center", justifyContent:"center", flexShrink:0 }}>
            <I n="settings" s={16} col={C.s700} sw={2}/>
          </button>
        </div>

        {/* Page content */}
        <div style={{ flex:1, overflowY:"auto" }}>
          <div key={page} style={{ animation:"fadeUp .25s ease" }}>
            {pages[page] || <div style={{ padding:40, textAlign:"center", color:C.ink3 }}>Page coming soon</div>}
          </div>
        </div>
      </div>

      <Toast/>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(<App/>);
  </script>
</body>
</html>
